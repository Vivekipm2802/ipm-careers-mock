# ============================================
# IPM Careers Mock - Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only service role key — do NOT prefix with NEXT_PUBLIC_
# (the NEXT_PUBLIC_ version still works as a fallback but exposes
# the key to the browser, which is a security risk)
SUPABASE_SERVICE_KEY=your-service-role-key

# --- SMTP / Email (ZeptoMail) ---
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=465
SMTP_USER=emailapikey
SMTP_PASS=your-zeptomail-api-key
EMAIL_FROM_NAME=IPM Careers
EMAIL_FROM_ADDR=info@ipmcareer.in

# --- OpenAI (for RC & Word generation) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Interakt (WhatsApp push notifications) --- CURRENTLY DISABLED
# Uncomment if re-enabling interakt.js
# NEXT_INTERAKT_KEY=your-interakt-base64-key

# --- PostHog (analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Cloudinary (image uploads) ---
NEXT_PUBLIC_CLOUDINARY_KEY=your-cloudinary-cloud-name
NEXT_PUBLIC_CLOUDINARY_IMAGE_PRESET=your-upload-preset

# --- BunnyCDN (video uploads) ---
NEXT_PUBLIC_BUNNYCDN_KEY=your-bunnycdn-access-key

# --- Print Service (separate Supabase project for admit card prints) ---
PRINT_SUPABASE_URL=https://your-print-project.supabase.co
PRINT_SUPABASE_SERVICE_KEY=your-print-service-role-key

# --- Admin Access ---
# Comma-separated list of admin email addresses
ADMIN_EMAILS=rishabhsingh0363@gmail.com,ipmcareeronline@gmail.com
